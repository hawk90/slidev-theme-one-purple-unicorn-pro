{
  "name": "slidev-theme-one-purple-unicorn-pro",
  "version": "0.6.1",
  "type": "module",
  "description": "One Purple Unicorn Pro theme for Slidev - Purple/Indigo focused theme with clean macOS style",
  "keywords": [
    "slidev-theme",
    "slidev"
  ],
  "engines": {
    "node": ">=14.0.0",
    "slidev": ">=0.47.0"
  },
  "author": {
    "name": "Hawk",
    "email": "hawking90a@gmail.com"
  },
  "main": "./index.ts",
  "files": [
    "index.ts",
"layouts/**/*",
    "styles/**/*",
    "setup/**/*",
    "uno.config.ts",
    "global-top.vue",
    "global-bottom.vue",
    "styles.css",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/hawk90/slidev-theme-one-purple-unicorn-pro"
  },
  "homepage": "https://github.com/hawk90/slidev-theme-one-purple-unicorn-pro",
  "bugs": {
    "url": "https://github.com/hawk90/slidev-theme-one-purple-unicorn-pro/issues"
  },
  "license": "MIT",
  "slidev": {
    "colorSchema": "both",
    "defaults": {
      "fonts": {
        "sans": "Noto Sans KR, Inter, system-ui",
        "serif": "Noto Serif KR",
        "mono": "JetBrains Mono, Fira Code, monospace"
      }
    }
  },
  "dependencies": {
    "@slidev/types": "latest",
    "codemirror-theme-vars": "^0.1.2",
    "prism-theme-vars": "^0.2.4",
    "theme-vitesse": "^0.6.0"
  },
  "devDependencies": {
    "postcss": "^8.4.24",
    "postcss-cli": "^10.1.0",
    "postcss-import": "^15.1.0",
    "postcss-nested": "^6.0.1",
    "postcss-custom-properties": "^13.1.4",
    "autoprefixer": "^10.4.14",
    "cssnano": "^6.0.1"
  },
  "scripts": {
    "dev": "echo 'Theme development mode - changes are automatically reflected'",
    "build": "echo 'Building theme...' && npm link",
    "watch": "echo 'Watching for changes...'",
    "link": "npm link && cd ../.. && npm link slidev-theme-one-purple-unicorn-pro",
    "unlink": "npm unlink && cd ../.. && npm unlink slidev-theme-one-purple-unicorn-pro",
    "prepublishOnly": "echo 'Preparing for publish...'"
  }
}